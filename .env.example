# ----------------------------------------------------------------------------
# NextAuth (admin panel)
# ----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"

# Admin login (credentials provider — checked against these env values)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# ----------------------------------------------------------------------------
# Public site config
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="FinPort"

# Content is served from static TS data (src/data). No database required.
# (A headless CMS like Sanity can replace src/data later.)
