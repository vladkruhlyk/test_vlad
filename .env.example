# ----------------------------------------------------------------------------
# Database
# Local development uses SQLite (zero-config). For production, switch the
# provider in prisma/schema.prisma to "postgresql" and set a Postgres URL.
# ----------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_URL="postgresql://user:password@host:5432/fintech?schema=public"

# ----------------------------------------------------------------------------
# NextAuth
# ----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-with-openssl-rand-base64-32"

# Admin bootstrap credentials (credentials provider demo)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123"

# ----------------------------------------------------------------------------
# Public site config
# ----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="FinPort"
